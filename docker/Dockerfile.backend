# Backend Dockerfile (Node.js)
# Copy this file to your backend repository root (e.g. api-node-prisma-avanti-bootcamp/Dockerfile)

FROM node:18-alpine

# Create app directory
WORKDIR /usr/src/app

# Install app dependencies
COPY package*.json ./
RUN npm ci --only=production

# Bundle app source
COPY . .

# Expose port
EXPOSE 3000

# Use the start script defined in package.json
CMD ["npm", "start"]