// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum TipoUsuario {
  ALUNO
  ESPECIALISTA
}

model Pessoa {
  id                    String         @id @default(uuid())
  nome                  String
  email                 String         @unique
  senha                 String
  cpf                   String?
  telefone              String
  descricao             String?
  foto                  String?
  role                  Role           @default(USER)
  tipoUsuario           TipoUsuario    @default(ALUNO)
  // Campos profissionais (apenas para ESPECIALISTA)
  areaAtuacao           String?
  uf                    String?
  linkPortfolio         String?
  especialidadePrincipal String?
  ofertas               Conhecimento[]
}

model Conhecimento {
  id          String   @id @default(uuid())
  titulo      String
  descricao   String
  categoria   String
  nivel       String
  pessoa_id   String
  responsavel Pessoa   @relation(fields: [pessoa_id], references: [id])
}